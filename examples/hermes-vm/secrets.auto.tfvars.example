# Copy to `secrets.auto.tfvars` (gitignored) and fill in real values.
# These become Secret Manager versions; values land in terraform.tfstate in
# plaintext, so treat state as sensitive (it is gitignored + local-only).
#
# Keys MUST be a subset of var.secret_keys. Omit any you'd rather set via
# `gcloud secrets versions add` instead (pick ONE writer per key).
#
# Do NOT set SSH_TARGET_USER / SSH_TARGET_KEY here — the module generates them.

secret_values = {
  LITELLM_BASE_URL = "https://your-litellm-proxy.example/v1"
  LITELLM_MODEL    = "your-model"
  LITELLM_API_KEY  = "sk-REPLACE-ME"
  # HERMES_PEER_NAME      = "default-user"
  # DISCORD_BOT_TOKEN     = "..."
  # DISCORD_ALLOWED_USERS = "..."
  # GH_TOKEN              = "ghp_..."
}
